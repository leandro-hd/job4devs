# Database
DATABASE_URL=postgresql://user:password@localhost:5432/job4devs

# Auth
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Email (Resend)
RESEND_API_KEY=re_xxx
EMAIL_FROM="job4devs <alerts@job4devs.dev>"

# Worker
DEFAULT_CRON_INTERVAL_MINUTES=5

# URLs
# In production these point to the deployed frontend/backend (CORS uses FRONTEND_URL).
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:3000

# Server
PORT=3000
